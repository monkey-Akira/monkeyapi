# Copy this file to .env.production on the Linux server, then edit the values.
# Do not commit .env.production.

# Public access URL. Use your real domain after Nginx/HTTPS is ready.
FRONTEND_BASE_URL=https://api.example.com

# Host bind and app port. Keep HOST_BIND=127.0.0.1 when using Nginx reverse proxy.
HOST_BIND=127.0.0.1
APP_PORT=3000
TZ=Asia/Shanghai
NODE_NAME=monkeyapi-node-1

# PostgreSQL. Use only letters, numbers, underscore, dash, or dot unless you know
# how to URL-encode special characters for SQL_DSN.
POSTGRES_USER=root
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=new-api

# Redis. Use only letters, numbers, underscore, dash, or dot.
REDIS_PASSWORD=change_this_redis_password

# Generate on the server with:
#   openssl rand -hex 32
SESSION_SECRET=change_this_session_secret
